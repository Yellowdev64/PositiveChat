  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>PositiveChat</name>
  <summary>Encrypted P2P chat with positive placeholders</summary>
  <description>
    <p>A fully encrypted, serverless peer-to-peer chat app for Linux. Messages are protected with PyNaCl and display as uplifting placeholders until the receiver decrypts them.</p>
    <p>Features:</p>
    <ul>
      <li>End-to-end encryption (no cloud servers)</li>
      <li>QR code LAN peer discovery</li>
      <li>Positive message placeholders</li>
      <li>Local profile system</li>
      <li>Modern dark-mode UI</li>
    </ul>
  </description>
